# API server
APP_HOST=127.0.0.1
APP_PORT=8001
APP_RELOAD=true

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=explorer
POSTGRES_PASSWORD=explorer
POSTGRES_DB=explorer_net

# SQLAlchemy (sync + async)
DATABASE_URL=postgresql+psycopg://explorer:explorer@localhost:5432/explorer_net
ASYNC_DATABASE_URL=postgresql+asyncpg://explorer:explorer@localhost:5432/explorer_net

# Redis
REDIS_URL=redis://localhost:6379/0

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=explorer
MONGO_PASSWORD=explorer
MONGO_DB=explorer_net
MONGO_URL=mongodb://explorer:explorer@localhost:27017/explorer_net?authSource=admin

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
